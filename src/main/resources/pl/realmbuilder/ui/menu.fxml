<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="pl.realmbuilder.ui.MenuController"
      alignment="CENTER"
      spacing="25"
      styleClass="menu-root">

    <Label text="⚔ REALM BUILDER ⚔" styleClass="menu-title"/>

    <Label text="Zbuduj potężne miasto. Przetrwaj 80 tur." styleClass="menu-subtitle"/>

    <VBox spacing="15" alignment="CENTER" styleClass="menu-panel" maxWidth="450">

        <Label text="Nazwa Twojego miasta:" styleClass="menu-label"/>
        <TextField fx:id="cityNameField"
                   promptText="Wpisz nazwę miasta..."
                   maxWidth="350"
                   styleClass="menu-textfield"/>

        <Label text="Wybierz poziom trudności:" styleClass="menu-label"/>

        <HBox spacing="12" alignment="CENTER">
            <ToggleButton fx:id="easyBtn" text="⭐ Łatwy" styleClass="menu-toggle"/>
            <ToggleButton fx:id="normalBtn" text="⭐⭐ Normalny" selected="true" styleClass="menu-toggle"/>
            <ToggleButton fx:id="hardBtn" text="⭐⭐⭐ Trudny" styleClass="menu-toggle"/>
        </HBox>
    </VBox>

    <Button text="▶ Rozpocznij" onAction="#onStartGame" styleClass="menu-btn-start"/>

    <Button text="📂 Wczytaj zapis gry" onAction="#onLoadGame" styleClass="menu-btn-load"/>

    <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 14px; -fx-font-weight: bold;"/>

</VBox>