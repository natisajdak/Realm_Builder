<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="pl.realmbuilder.ui.EndScreenController"
      alignment="CENTER"
      spacing="18"
      styleClass="end-root">

    <VBox alignment="CENTER" spacing="7" styleClass="end-header" maxWidth="600">
        <Label fx:id="resultLabel" text="WYGRANA!" styleClass="end-title"/>
        <Label fx:id="rankLabel" text="" styleClass="end-rank"/>
        <Label fx:id="rankDescLabel" text="" wrapText="true" styleClass="end-rank-desc" alignment="CENTER" maxWidth="520"/>
        <Label fx:id="scoreLabel" text="" styleClass="end-score"/>
    </VBox>

    <HBox spacing="12" alignment="CENTER" maxWidth="600">
        <VBox alignment="CENTER" spacing="5" styleClass="end-stat-card" HBox.hgrow="ALWAYS">
            <Label text="Tury" styleClass="end-stat-label"/>
            <Label fx:id="turnsLabel" text="0" styleClass="end-stat-value"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5" styleClass="end-stat-card" HBox.hgrow="ALWAYS">
            <Label text="Złoto" styleClass="end-stat-label"/>
            <Label fx:id="goldLabel" text="0" styleClass="end-stat-value"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5" styleClass="end-stat-card" HBox.hgrow="ALWAYS">
            <Label text="Populacja" styleClass="end-stat-label"/>
            <Label fx:id="popLabel" text="0" styleClass="end-stat-value"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5" styleClass="end-stat-card" HBox.hgrow="ALWAYS">
            <Label text="Morale" styleClass="end-stat-label"/>
            <Label fx:id="moraleLabel" text="0" styleClass="end-stat-value"/>
        </VBox>
    </HBox>

    <VBox spacing="8" styleClass="end-section" maxWidth="600" VBox.vgrow="ALWAYS">
        <Label text="Osiągnięcia" styleClass="end-section-title"/>
        <ListView fx:id="achievementsList" prefHeight="130" styleClass="parchment-list"/>
    </VBox>

    <Button text="Powrót do menu" onAction="#onBackToMenu" styleClass="btn-primary" prefWidth="230"/>

</VBox>
